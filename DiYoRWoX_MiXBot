import os
import logging
from telegram import Update, InlineKeyboardButton, InlineKeyboardMarkup
from telegram.ext import (
    Application, CommandHandler, MessageHandler,
    CallbackQueryHandler, ContextTypes, filters
)
from yt_dlp import YoutubeDL
import sqlite3

logging.basicConfig(level=logging.INFO)
logger = logging.getLogger(__name__)

BOT_TOKEN = os.getenv("BOT_TOKEN", "YOUR_BOT_TOKEN_HERE")

def init_db():
    conn = sqlite3.connect("music.db")
    c = conn.cursor()
    c.execute('''CREATE TABLE IF NOT EXISTS songs (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        user_id INTEGER,
        title TEXT,
        file_id TEXT,
        uploaded_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
    )''')
    conn.commit()
    conn.close()

def save_song(user_id, title, file_id):
    conn = sqlite3.connect("music.db")
    c = conn.cursor()
    c.execute("INSERT INTO songs (user_id, title, file_id) VALUES (?, ?, ?)", (user_id, title, file_id))
    conn.commit()
    conn.close()

def get_user_songs(user_id):
    conn = sqlite3.connect("music.db")
    c = conn.cursor()
    c.execute("SELECT id, title, file_id FROM songs WHERE user_id=? ORDER BY uploaded_at DESC", (user_id,))
    songs = c.fetchall()
    conn.close()
    return songs

def delete_song(song_id, user_id):
    conn = sqlite3.connect("music.db")
    c = conn.cursor()
    c.execute("DELETE FROM songs WHERE id=? AND user_id=?", (song_id, user_id))
    conn.commit()
    conn.close()

async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    await update.message.reply_text(
        "🎵 *Musiqa Botiga Xush Kelibsiz!*\n\n"
        "🔍 `/qidir [qo'shiq nomi]` — Musiqa qidirish\n"
        "🎤 Audio fayl yuboring — qo'shiq saqlanadi\n"
        "📂 `/mening_qoshiqlarim` — Saqlangan qo'shiqlar\n"
        "❓ `/yordam` — Yordam\n\n"
        "Keling, musiqa topaylik! 🎶",
        parse_mode="Markdown"
    )

async def yordam(update: Update, context: ContextTypes.DEFAULT_TYPE):
    await update.message.reply_text(
        "❓ *Yordam*\n\n"
        "🔍 `/qidir Shodlik Toshmatov`\n"
        "🎤 Audio fayl yuboring — saqlanadi\n"
        "📂 `/mening_qoshiqlarim` — ro'yxat\n",
        parse_mode="Markdown"
    )

async def qidir(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if not context.args:
        await update.message.reply_text("❗ Misol: `/qidir Ozodbek Nazarbekov`", parse_mode="Markdown")
        return
    query = " ".join(context.args)
    msg = await update.message.reply_text(f"🔍 *{query}* qidirilmoqda...", parse_mode="Markdown")
    try:
        ydl_opts = {'quiet': True, 'skip_download': True, 'extract_flat': True}
        with YoutubeDL(ydl_opts) as ydl:
            info = ydl.extract_info(f"ytsearch5:{query}", download=False)
            results = info.get('entries', [])
        if not results:
            await msg.edit_text("❌ Hech narsa topilmadi.")
            return
        keyboard = []
        for r in results[:5]:
            title = r.get('title', 'Nomsiz')[:50]
            url = r.get('url') or r.get('webpage_url', '')
            keyboard.append([InlineKeyboardButton(f"🎵 {title}", callback_data=f"dl|{url}")])
        await msg.edit_text(f"🎶 Natijalar:", reply_markup=InlineKeyboardMarkup(keyboard), parse_mode="Markdown")
    except Exception as e:
        logger.error(e)
        await msg.edit_text("❌ Xato yuz berdi.")

async def yuklab_ol(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()
    url = query.data[3:]
    msg = await query.edit_message_text("⬇️ Yuklanmoqda...")
    try:
        ydl_opts = {
            'format': 'bestaudio/best',
            'outtmpl': '/tmp/%(title)s.%(ext)s',
            'postprocessors': [{'key': 'FFmpegExtractAudio', 'preferredcodec': 'mp3', 'preferredquality': '192'}],
            'quiet': True,
        }
        with YoutubeDL(ydl_opts) as ydl:
            info = ydl.extract_info(url, download=True)
            title = info.get('title', 'Musiqa')
            filename = ydl.prepare_filename(info).replace('.webm', '.mp3').replace('.m4a', '.mp3')
        with open(filename, 'rb') as f:
            await context.bot.send_audio(chat_id=query.message.chat_id, audio=f, title=title)
        os.remove(filename)
        await msg.delete()
    except Exception as e:
        logger.error(e)
        await msg.edit_text("❌ Yuklab bo'lmadi.")

async def audio_qabul(update: Update, context: ContextTypes.DEFAULT_TYPE):
    audio = update.message.audio or update.message.voice
    if not audio:
        return
    user_id = update.message.from_user.id
    file_id = audio.file_id
    title = getattr(audio, 'title', None) or 'Nomsiz qo\'shiq'
    save_song(user_id, title, file_id)
    await update.message.reply_text(f"✅ *{title}* saqlandi!", parse_mode="Markdown")

async def mening_qoshiqlarim(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user_id = update.message.from_user.id
    songs = get_user_songs(user_id)
    if not songs:
        await update.message.reply_text("📂 Hali qo'shiq saqlanmagan.")
        return
    keyboard = []
    text = "🎵 *Sizning qo'shiqlaringiz:*\n\n"
    for i, (song_id, title, file_id) in enumerate(songs, 1):
        text += f"{i}. {title}\n"
        keyboard.append([
            InlineKeyboardButton(f"▶️ {title[:30]}", callback_data=f"play|{file_id}"),
            InlineKeyboardButton("🗑", callback_data=f"del|{song_id}")
        ])
    await update.message.reply_text(text, reply_markup=InlineKeyboardMarkup(keyboard), parse_mode="Markdown")

async def qoshiq_amal(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()
    if query.data.startswith("play|"):
        await context.bot.send_audio(chat_id=query.message.chat_id, audio=query.data[5:])
    elif query.data.startswith("del|"):
        delete_song(int(query.data[4:]), query.from_user.id)
        await query.edit_message_text("🗑 O'chirildi.")

def main():
    init_db()
    app = Application.builder().token(BOT_TOKEN).build()
    app.add_handler(CommandHandler("start", start))
    app.add_handler(CommandHandler("yordam", yordam))
    app.add_handler(CommandHandler("qidir", qidir))
    app.add_handler(CommandHandler("mening_qoshiqlarim", mening_qoshiqlarim))
    app.add_handler(MessageHandler(filters.AUDIO | filters.VOICE, audio_qabul))
    app.add_handler(CallbackQueryHandler(yuklab_ol, pattern="^dl\\|"))
    app.add_handler(CallbackQueryHandler(qoshiq_amal, pattern="^(play|del)\\|"))
    logger.info("Bot ishga tushdi!")
    app.run_polling()

if __name__ == "__main__":
    main()
